// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "bindings": {
      "f10": "debugger::StepOver"
    }
  },
  {
    "unbind": {
      "f7": "debugger::StepOver"
    }
  },
  {
    "bindings": {
      "shift-f10": "debugger::StepBack"
    }
  },
  {
    "unbind": {
    }
  },
  {
    "context": "vim_mode == normal || vim_mode == visual || vim_mode == operator",
    "bindings": {
      "alt-shift-k": "editor::MoveLineUp"
    }
  },
  {
    "context": "vim_mode == normal || vim_mode == visual || vim_mode == operator",
    "unbind": {
      "[ e": "editor::MoveLineUp"
    }
  },
  {
    "context": "vim_mode == normal || vim_mode == visual || vim_mode == operator",
    "bindings": {
      "alt-shift-j": "editor::MoveLineDown"
    }
  },
  {
    "context": "vim_mode == normal || vim_mode == visual || vim_mode == operator",
    "unbind": {
      "] e": "editor::MoveLineDown"
    }
  },
  {
    "unbind": {
      "shift-escape": "workspace::ToggleZoom"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-;": "editor::ToggleLineNumbers"
    }
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "ctrl-l": [
        "editor::ToggleComments",
        {
          "advance_downwards": false
        }
      ]
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-;": [
        "editor::ToggleComments",
        {
          "advance_downwards": false
        }
      ]
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-/": [
        "editor::ToggleComments",
        {
          "advance_downwards": false
        }
      ]
    }
  },
  {
    "context": "vim_mode == insert ",
    "bindings": {
      "shift-escape": "vim::NormalBefore"
    }
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "ctrl-b": "vim::PageUp"
    }
  },
  {
    "context": "AcpThread > Editor",
    "unbind": {
      "ctrl-'": "agent::CycleThinkingEffort"
    }
  },
  {
    "context": "SettingsWindow",
    "unbind": {
      "ctrl-,": "settings_editor::OpenCurrentFile"
    }
  },
  {
    "context": "!SettingsWindow",
    "unbind": {
      "ctrl-,": "zed::OpenSettings"
    }
  },
  {
    "unbind": {
      "ctrl-alt-,": "zed::OpenSettingsFile"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-,": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-`": "terminal_panel::Toggle"
    }
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "alt-d": "vim::SelectNext"
    }
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "g j": "vim::Down"
    }
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "j": [
        "vim::Down",
        {
          "display_lines": true
        }
      ]
    }
  },
  {
    "context": "VimControl && vim_mode == helix_normal && !menu && !BufferSearchBar",
    "bindings": {
      "g k": [
        "vim::Up",
        {
          "display_lines": true
        }
      ]
    }
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "k": [
        "vim::Up",
        {
          "display_lines": true
        }
      ]
    }
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "unbind": {
      "alt-d": "editor::Delete"
    }
  },
  {
    "context": "ProjectPanel",
    "unbind": {
      "alt-d": "project_panel::CompareMarkedFiles"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "alt-j": "workspace::ActivatePaneDown"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w j": "workspace::ActivatePaneDown"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "alt-h": "workspace::ActivatePaneLeft"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w h": "workspace::ActivatePaneLeft"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "alt-l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "alt-k": "workspace::ActivatePaneUp"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w k": "workspace::ActivatePaneUp"
    }
  },
  {
    "bindings": {
      "alt-,": "terminal_panel::ToggleFocus"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-,": "workspace::ToggleBottomDock"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-j": "workspace::ToggleBottomDock"
    }
  }
]
